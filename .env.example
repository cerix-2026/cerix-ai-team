# CeriX CEO-AI Environment Variables
# Copy to .env and fill in values

# Server
PORT=3000
NODE_ENV=production

# OpenRouter API
OPENROUTER_API_KEY=sk-or-v1-your-key-here
CLAUDE_MODEL=anthropic/claude-sonnet-4

# MySQL (Railway provides these automatically)
MYSQL_URL=mysql://root:password@host:port/railway
MYSQLHOST=localhost
MYSQLPORT=3306
MYSQLUSER=root
MYSQLPASSWORD=
MYSQLDATABASE=railway

# Gmail MCP (optional)
GMAIL_MCP_URL=https://gmail.mcp.claude.com/mcp
